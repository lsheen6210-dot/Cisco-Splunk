Type}#Id":"0x01000AECFEB6BC886945AFB41E375AF38B0C00599C7CD5C02CF9419591E10396B87DB5","{HasAttachments}":false,"{VersionNumber}":"2.0"},{"@odata.etag":"\"2\"","ItemInternalId":"22","ID":22,"Title":"Speeding up sysmon queries in the cloud or onprem","Category":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedReference","Id":1,"Value":"LinkedIn Article"},"Category#Id":1,"Description":"Sysmon data is fantastic for security and other use cases, and there's even a sysmon app to help you look at all that pretty data. Unfortunately, out of the box, the sysmon app requires some expensive queries due to the lack of indexed fields in the data. For example, The Overview page has simple information such as a stats count of events by EventDescription. This step by step guid will detail a method to dynamically create props and transforms to index the sysmon Descriptions as META data, and let your SPL fly!","Link_x002f_Url":"https://cisco-my.sharepoint.com/:w:/p/jschogel/IQC-BAa2M504UKF7ykj_SiceAWn1SQg46ssnRfyyPwwIPM8?e=24PO6t","Status":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedReference","Id":1,"Value":"Approved"},"Status#Id":1,"Author":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedUser","Claims":"i:0#.f|membership|jschogel@cisco.com","DisplayName":"Jason Schogel (jschogel)","Email":"jschogel@cisco.com","Picture":"https://cisco.sharepoint.com/sites/SplunkIndustryTeam/_layouts/15/UserPhoto.aspx?Size=L&AccountName=jschogel@cisco.com","Department":"020534127","JobTitle":"Solutions Engineer"},"Author#Claims":"i:0#.f|membership|jschogel@cisco.com","OData__FormSourceId_0":"0218ecd2-bfe7-437d-b44e-9d71e5753db0","Modified":"2026-05-13T14:38:22Z","Created":"2026-05-13T14:35:40Z","Editor":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedUser","Claims":"i:0#.f|membership|lsheen@cisco.com","DisplayName":"Liam Sheen (lsheen)","Email":"lsheen@cisco.com","Picture":"https://cisco.sharepoint.com/sites/SplunkI