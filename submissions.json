JobTitle":"Solutions Engineer"},"Editor#Claims":"i:0#.f|membership|lsheen@cisco.com","{Identifier}":"Lists%252fKnowledge%2b%2bContent%2bSubmissions%252f20_.000","{IsFolder}":false,"{Thumbnail}":{"Large":null,"Medium":null,"Small":null},"{Link}":"https://cisco.sharepoint.com/sites/SplunkIndustryTeam/_layouts/15/listform.aspx?PageType=4&ListId=4cd63548%2Deac9%2D4868%2Da7b9%2Dc1e92889dcc5&ID=20&ContentTypeID=0x01000AECFEB6BC886945AFB41E375AF38B0C00599C7CD5C02CF9419591E10396B87DB5","{Name}":"Splunk Use Case Catalog","{FilenameWithExtension}":"Splunk Use Case Catalog","{Path}":"Lists/Knowledge  Content Submissions/","{FullPath}":"Lists/Knowledge  Content Submissions/20_.000","{ContentType}":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedContentType","Id":"0x01000AECFEB6BC886945AFB41E375AF38B0C00599C7CD5C02CF9419591E10396B87DB5","Name":"Item"},"{ContentType}#Id":"0x01000AECFEB6BC886945AFB41E375AF38B0C00599C7CD5C02CF9419591E10396B87DB5","{HasAttachments}":true,"{VersionNumber}":"3.0"},{"@odata.etag":"\"2\"","ItemInternalId":"21","ID":21,"Title":"Getting Use Case Insights to on-prem Deployments with No Telemetry Shared ","Category":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedReference","Id":1,"Value":"LinkedIn Article"},"Category#Id":1,"Description":"Documented method for getting Use Case Insights to on-prem Deployments when there is no Telemetry Shared. This is a write up of how I recreated dashboards from uploaded diags, when my customer was not including the apps dir in the diag upload. This is a real customer, so information from this can not be share outside of Splunk, though the method is documented and can be done with any customer. Note, their deployment must have a SHC for this method to work, and some SH diags that you can download from support or sfdc cases.","Link_x002f_Url":"https://cisco-my.sharepoint.com/:w:/p/jschogel/IQAGdX87PHnjX99DycByk821AYswW88q8fkNX-HfPJGersM?e=q6tb2C","Status":{"@odata.type":"#Microsoft.A