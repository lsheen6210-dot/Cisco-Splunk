n@cisco.com","Department":"020534127","JobTitle":"Solutions Engineer"},"Author#Claims":"i:0#.f|membership|lsheen@cisco.com","OData__FormSourceId_0":"0218ecd2-bfe7-437d-b44e-9d71e5753db0","Modified":"2026-05-06T19:05:30Z","Created":"2026-05-06T18:59:54Z","Editor":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedUser","Claims":"i:0#.f|membership|lsheen@cisco.com","DisplayName":"Liam Sheen (lsheen)","Email":"lsheen@cisco.com","Picture":"https://cisco.sharepoint.com/sites/SplunkIndustryTeam/_layouts/15/UserPhoto.aspx?Size=L&AccountName=lsheen@cisco.com","Department":"020534127","JobTitle":"Solutions Engineer"},"Editor#Claims":"i:0#.f|membership|lsheen@cisco.com","{Identifier}":"Lists%252fKnowledge%2b%2bContent%2bSubmissions%252f15_.000","{IsFolder}":false,"{Thumbnail}":{"Large":null,"Medium":null,"Small":null},"{Link}":"https://cisco.sharepoint.com/sites/SplunkIndustryTeam/_layouts/15/listform.aspx?PageType=4&ListId=4cd63548%2Deac9%2D4868%2Da7b9%2Dc1e92889dcc5&ID=15&ContentTypeID=0x01000AECFEB6BC886945AFB41E375AF38B0C00599C7CD5C02CF9419591E10396B87DB5","{Name}":"Test","{FilenameWithExtension}":"Test","{Path}":"Lists/Knowledge  Content Submissions/","{FullPath}":"Lists/Knowledge  Content Submissions/15_.000","{ContentType}":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedContentType","Id":"0x01000AECFEB6BC886945AFB41E375AF38B0C00599C7CD5C02CF9419591E10396B87DB5","Name":"Item"},"{ContentType}#Id":"0x01000AECFEB6BC886945AFB41E375AF38B0C00599C7CD5C02CF9419591E10396B87DB5","{HasAttachments}":false,"{VersionNumber}":"2.0"},{"@odata.etag":"\"3\"","ItemInternalId":"17","ID":17,"Title":"Splunk Security Content","Category":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedReference","Id":2,"Value":"General Knowledge"},"Category#Id":2,"Description":"Do you or your customer know about the free Splunk Security Content published by the Splunk Threat Research team biweekly?\n\nIf so, great. If not, please read on!\n\nThis is a game changer when it comes to building trust, and establishing a true partnership where our customer can actively look to us for security content and help when they are in a tough spot.\n\nIf your customer has Splunk core, or even better, Splunk Enterprise Security, bring this up in the next conversation you have with them. Ask the simple question: \"have you ever heard of our Splunk Security content site?\" If they haven't, link them here and share you screen.\n\nhttps://research.splunk.com/\n\nI like to enter into a scenario where the customer would be working to prevent against a recently published exploit, for example the Axios Supply Chain Post Compromise.\n\nYou would navigate to Analytic Stories, type in \"Axios\", or a similar keyword, and present the detections that are available. Normally the customer asks \"what data sources do I need?\", you could then show that they are available on that page.\n\nBoom. You just gave them access to 2000 free detections that will help strengthen their posture. Great job. Now work with your RSM to send your customers a Splunk t shirt! \n\nhttps://merchandise.cisco.com/splunk/apparel.html","Link_x002f_Url":"https://research.splunk.com/detections/","Status":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedReference","Id":1,"Value":"Approved"},"Status#Id":1,"Author":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedUser","Claims":"i:0#.f|membership|dfurtaw@cisco.com","DisplayName":"Daniel Furtaw (dfurtaw)","Email":"dfurtaw@cisco.com","Picture":"https://cisco.sharepoint.com/sites/SplunkIndustryTeam/_layouts/15/UserPhoto.aspx?Size=L&AccountName=dfurtaw@cisco.com","Department":"020534127","JobTitle":"Solutions Engineer"},"Author#Claims":"i:0#.f|membership|dfurtaw@cisco.com","OData__FormSourceId_0":"0218ecd2-bfe7-437d-b44e-9d71e5753db0","Modified":"2026-05-12T13:21:18Z","Created":"2026-05-12T13:12:57Z","Editor":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedUser","Claims":"i:0#.f|membership|lsheen@cisco.com","DisplayName":"Liam Sheen (lsheen)","Email":"lsheen@cisco.com","Picture":"https://cisco.sharepoint.com/sites/SplunkIndustryTeam/_layouts/15/UserPhoto.aspx?Size=L&AccountName=lsheen@cisco.com","Department":"020534127","JobTitle":"Solutions Engineer"},"Editor#Claims":"i:0#.f|membership|lsheen@cisco.com","{Identifier}":"Lists%252fKnowledge%2b%2bContent%2bSubmissions%252f17_.000","{IsFolder}":false,"{Thumbnail}":{"Large":null,"Medium":null,"Small":null},"{Link}":"https://cisco.sharepoint.com/sites/SplunkIndustryTeam/_layouts/15/listform.aspx?PageType=4&ListId=4cd63548%2Deac9%2D4868%2Da7b9%2Dc1e92889dcc5&ID=17&ContentTypeID=0x01000AECFEB6BC886945AFB41E375AF38B0C00599C7CD5C02CF9419591E10396B87DB5","{Name}":"Splunk Security Content","{FilenameWithExtension}":"Splunk Security Content","{Path}":"Lists/Knowledge  Content Submissions/","{FullPath}":"Lists/Knowledge  Content Submissions/17_.000","{ContentType}":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedContentType","Id":"0x01000AECFEB6BC886945AFB41E375AF38B0C00599C7CD5C02CF9419591E10396B87DB5","Name":"Item"},"{ContentType}#Id":"0x01000AECFEB6BC886945AFB41E375AF38B0C00599C7CD5C02CF9419591E10396B87DB5","{HasAttachments}":true,"{VersionNumber}":"3.0"},{"@odata.etag":"\"2\"","ItemInternalId":"18","ID":18,"Title":"Circuit Agent Studio","Category":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedReference","Id":2,"Value":"General Knowledge"},"Category#Id":2,"Description":"You can use Agent Studio to create some very useful agents that automate certain tasks. It only takes a few minutes to get start building your agent. The studio walks you through requirements gathering, technical scoping, architecture, design, and testing. You can continue to use your agent privately at your leisure, and if you wish to share it with your team, you can register it!\n\nI have linked an example chat with the agent I created.\n\nExamples that I have personally done:\n- Demo Helper for Splunk SEs: Creates tailored data strategy and recommended flow, along with code for custom data generation (batch or live), and custom JSON for Dashboard Studio\n- Technical Onboarding Challenges: Platform I developed for my mentees that walks them through specific technical challenges within Splunk, gauging sentiment and providing hints, but not solving the problem for them.","Link_x002f_Url":"https://circuit.cisco.com/app/share?link_id=3ad68d02f315a9af-221bfa1d73464869-7c479c5c9deaa7fe","Status":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedReference","Id":1,"Value":"Approved"},"Status#Id":1,"Author":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedUser","Claims":"i:0#.f|membership|libbykr@cisco.com","DisplayName":"Libby Kraemer (libbykr)","Email":"libbykr@cisco.com","Picture":"https://cisco.sharepoint.com/sites/SplunkIndustryTeam/_layouts/15/UserPhoto.aspx?Size=L&AccountName=libbykr@cisco.com","Department":"020534127","JobTitle":"Solutions Engineer"},"Author#Claims":"i:0#.f|membership|libbykr@cisco.com","OData__FormSourceId_0":"0218ecd2-bfe7-437d-b44e-9d71e5753db0","Modified":"2026-05-12T13:34:19Z","Created":"2026-05-12T13:17:55Z","Editor":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedUser","Claims":"i:0#.f|membership|lsheen@cisco.com","DisplayName":"Liam Sheen (lsheen)","Email":"lsheen@cisco.com","Picture":"https://cisco.sharepoint.com/sites/SplunkIndustryTeam/_layouts/15/UserPhoto.aspx?Size=L&AccountName=lsheen@cisco.com","Department":"020534127","JobTitle":"Solutions Engineer"},"Editor#Claims":"i:0#.f|membership|lsheen@cisco.com","{Identifier}":"Lists%252fKnowledge%2b%2bContent%2bSubmissions%252f18_.000","{IsFolder}":false,"{Thumbnail}":{"Large":null,"Medium":null,"Small":null},"{Link}":"https://cisco.sharepoint.com/sites/SplunkIndustryTeam/_layouts/15/listform.aspx?PageType=4&ListId=4cd63548%2Deac9%2D4868%2Da7b9%2Dc1e92889dcc5&ID=18&ContentTypeID=0x01000AECFEB6BC886945AFB41E375AF38B0C00599C7CD5C02CF9419591E10396B87DB5","{Name}":"Circuit Agent Studio","{FilenameWithExtension}":"Circuit Agent Studio","{Path}":"Lists/Knowledge  Content Submissions/","{FullPath}":"Lists/Knowledge  Content Submissions/18_.000","{ContentType}":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedContentType","Id":"0x01000AECFEB6BC886945AFB41E375AF38B0C00599C7CD5C02CF9419591E10396B87DB5","Name":"Item"},"{ContentType}#Id":"0x01000AECFEB6BC886945AFB41E375AF38B0C00599C7CD5C02CF9419591E10396B87DB5","{HasAttachments}":false,"{VersionNumber}":"2.0"},{"@odata.etag":"\"2\"","ItemInternalId":"19","ID":19,"Title":"How do we as SE's have the AI conversation?","Category":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedReference","Id":2,"Value":"General Knowledge"},"Category#Id":2,"Description":"AI, AI, AI.... Take a shot every time you hear someone say it. Just kidding, please don't do that. \n\nIt's very obvious that AI has taken the spotlight of many of our former plays (Security, O11y, Fraud, etc), so it's important that we ride on the coattails and make the most out of the selling opportunity that it brings. Almost every customer I've worked with is working on one or more AI initiatives and they are generally looking to vendors to help them get these implemented. Like the great RSD Kevin St. Clair once said: \"These are opportunities where we can help the customer get promoted and higher up the chain in their organization\". Times like these can set us apart from the rest of the vendor competition and really build a career champion. Now you're probably wondering, what do we do? \n\nIf you're not an AI expert by now, that is totally fine. Our village has the resources, and our product has the technology that we need to help our customers. Let's start by breaking up AI into a few different categories.\n\nThe first category I will mention is the customer managed enterprise grade AI solutions like Claude, ChatGPT, Copilot and Gemini to name a few. Most customers have atleast one of these solutions implemented and it is absolutely crucial that we do our part in supplementing them. How do we do this?\n\nWe build the bridge to Splunk, the MCP server. The MCP server allows the AI applications to call to Splunk and pull data. Without this, Splunk is not a friendly application to the AI and customers will look elsewhere to pull their data. If you have not had the conversation on MCP with your customer (generally the Splunk engineer/admin team and champion), then please do this. It is a very straightforward installation, and installed as an app. And YES, RBAC can be deployed with it. This comes up quite frequently.\n\nhttps://help.splunk.com/en/splunk-cloud-platform/mcp-server-for-splunk-platform/1.1/configure-the-splunk-mcp-server\n\nNext up is the Generative AI conversation. Splunk offers Generative AI in our products, so it's best to point our customers in the direction of enabling this in their environment, and then work with them to ensure they are able to use it, and know best practices. Splunk started with the core AI Assistant which helped with SPL building, and has since built an AI assistant for Security inside of Enterprise Security, as well as a Splunk Observability AI Assistant. If the customer owns Splunk in any facet, you can enable an AI assistant. The customer will thank you if you guide them to doing so! \n\nMost customers will ask the question of \"how does it work in the back end?\"\n\nYou can answer with this:\nSAIA for SPL is using open source pretrained LLMs that are fine tuned with our own domain specific data and further augmented with RAG. The models are ours and not from a third party. We use multiple models, choosing the best ones to deliver the best outcomes for the specific tasks.\n\nAfter AI Assistants, the next category will be Agentic AI. In my opinion, this is where most of the curiosity lies. We are actively developing agentic AI into our platforms and features are being released almost weekly, for each product, please refer to the slack channels for the latest on what's coming. Since these features are so new, or even not yet out, it's important to work with your Solution Architect (Security, O11y, Cloud, AI) or Security Strategist (Rene Aguero and team) on positioning these solutions and presenting on them. Almost all of my accounts have shown interest in what Splunk has to offer from an Agentic AI perspective and all of the presentations I have seen from the strategist group, as well as the AI tiger team (Chris Masternak and team) have been received extremely well. These are great opportunities for us as SE's to discover and learn more about what initiatives are important, and maybe also identify some pain points or compelling events.\n\nLastly, Splunk can help monitor AI. This is huge, and I'm sure most customers are not thinking of Security or observability of their AI right now, most are focused on getting it implemented and getting ahead of the curve. When you are speaking with your customer, ask what they are doing to get visibility into what's happening on the LLM and if they're able to see the latency, quality, and risks. If they aren't, we have an answer for that! Join the #se-observability channel in Slack, and search for \"AI Agent Monitoring\".  Splunk is the best of breed in monitoring and we want to make sure the customer can confidently run their AI with Splunk showing them what is happening, in a secure fashion.\n\n*If you require assistance*\n\n\"How to engage either the AI Tiger Team or AI Solutions Architects in The Americas:\nOpen an INH > Technical Sales Assistance > Demonstration/Presentation > Machine Learning.\nThe AI SA team manages this ticket queue. Depending on the nature of the request, an SA may handle the ticket or delegate to a Tiger Team member.\"\n\nIf you need to ask questions of any security related AI feature:\n\nInitiatives\nSaiGanesh Gopalakrishnan\n-AI for Detection Engineers\n-Detection Builder Agent\n-Log-reasoning Model\n-Foundation AI\n\nNicholas Astor/Seth Spiel\n-AI for Investigation\n-AI for Response\n-SOP Agent\n-Guided Response Agent\n-Triage Agent\n-Automation Builder Agent\n-AI Canvas\n\nAditya Raj\n-Unified Agentic Chat\n-Attack Analyzer\n-Malware Reversing Agent\n-Phishing Agent\n\nMohit Verma\n-SPL Assistant\n\nNeal Iyer\n-All other Security AI requests\n","Status":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedReference","Id":1,"Value":"Approved"},"Status#Id":1,"Author":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedUser","Claims":"i:0#.f|membership|dfurtaw@cisco.com","DisplayName":"Daniel Furtaw (dfurtaw)","Email":"dfurtaw@cisco.com","Picture":"https://cisco.sharepoint.com/sites/SplunkIndustryTeam/_layouts/15/UserPhoto.aspx?Size=L&AccountName=dfurtaw@cisco.com","Department":"020534127","JobTitle":"Solutions Engineer"},"Author#Claims":"i:0#.f|membership|dfurtaw@cisco.com","OData__FormSourceId_0":"0218ecd2-bfe7-437d-b44e-9d71e5753db0","Modified":"2026-05-12T14:08:34Z","Created":"2026-05-12T13:40:42Z","Editor":{"@odata.type":"#Microsoft.Azure.Connectors.SharePoint.SPListExpandedUser","Claims":"i:0#.f|membership|lsheen@cisco.com","DisplayName":"Liam Sheen (lsheen)","Email":"lsheen@cisco.com","Picture":"https://cisco.sharepoint.com/sites/SplunkIndustryTeam/_layouts/15/UserPhoto.aspx?Size=L&AccountName=lsheen@cisco.com","Department":"020534127","JobTitle":"Solutions Engineer"},"Editor#Claims":"i:0#.f|membership|lsheen@cisco.com","{Identifier}":"Lists%252fKnowledge%2b%2bContent%2bSubmissions%252f19_.000","{IsFolder}":false,"{Thumbnail}":{"Large":null,"Medium":null,"Small":null},"{Link}":"https://cisco.sharepoint.com/sites/SplunkIndustryTeam/_layouts/15/listform.aspx?PageType=4&ListId=4cd63548%2Deac9%2D4868%2Da7b9%2Dc1e92889dcc5&ID=19&ContentTypeID=0x01000AECFEB6BC886945AFB41E375AF38B0C00599C7CD5C02CF9419591E10396B87DB5","{Name}":"How do we as SE's have the AI conversation?","{FilenameWithExtensi